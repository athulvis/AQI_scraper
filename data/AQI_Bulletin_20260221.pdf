@-webkit-keyframes glowing {
  0% { background-color: #24B200; -webkit-box-shadow: 0 0 3px #24B200; }
  50% { background-color: #24B200; -webkit-box-shadow: 0 0 40px #24B200; }
  100% { background-color: #24B200; -webkit-box-shadow: 0 0 3px #24B200; }
}

@-moz-keyframes glowing {
  0% { background-color: #24B200; -moz-box-shadow: 0 0 3px #24B200; }
  50% { background-color: #24B200; -moz-box-shadow: 0 0 40px #24B200; }
  100% { background-color: #24B200; -moz-box-shadow: 0 0 3px #24B200; }
}

@-o-keyframes glowing {
  0% { background-color: #24B200; box-shadow: 0 0 3px #24B200; }
  50% { background-color: #24B200; box-shadow: 0 0 40px #24B200; }
  100% { background-color: #24B200; box-shadow: 0 0 3px #24B200; }
}

@keyframes glowing {
  0% { background-color: #24B200; box-shadow: 0 0 3px #24B200; }
  50% { background-color: #24B200; box-shadow: 0 0 40px #24B200; }
  100% { background-color: #24B200; box-shadow: 0 0 3px #24B200;; }
}

