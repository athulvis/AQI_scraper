               function tabClickSearch(e){
                var search_bx_k = $('#search_bx_k').val();
				//$("#testCSS").width() != 3);
				var chk_cssoffon = $("#search_bx_k").width();
				if(chk_cssoffon==3){
					if(search_bx_k==0){
						$("#search-cpcb").click();
						$("#gsc-i-id1").focus();
						$('#gsc-search-button-data').removeAttr('style');
						$('#search_bx_k').val(1);
					}
				}else{
					$('#search_bx_k').val(1);
				}
                
                
             }
              function tabColor(data){
               var google_lenghtR = $('#gsc-i-id1').val().length;
      
                if(google_lenghtR){
                  if(data==2){
                    $('#gsc-search-button-data').removeAttr('style');
                  }
                }else if(!google_lenghtR){
                  if(data==1){
                    $('#gsc-search-button-data').removeAttr('style');
                  }
                }
                if(data==3){
                  $('#gsc-search-button-data').css({"border-color":"red"});
                }
                if(data==4){
                  $('#gsc-search-button-data').removeAttr('style');
                }

             }

            </script>
