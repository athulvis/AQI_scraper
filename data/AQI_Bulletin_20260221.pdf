 <script>
  function fontdata(data){
      var keycode = (event.keyCode ? event.keyCode : event.which);
      if(keycode==13 && data=='normal'){
      $('#nrf').click();
      }
      if(keycode==13 && data=='increase'){
        $('#inf').click();
      }
      if(keycode==13 && data=='decrease'){
        $('#dcf').click();
      }
  }
function setActiveStyleSheet(title) {
  var colorName = title;
  if(colorName == 'light-blue'){
     $("#color").attr("href", "https://cpcb.nic.in/css/light-blue.css");
  }else if(colorName == 'blue'){
     $("#color").attr("href", "https://cpcb.nic.in/css/blue.css");
  }else if(colorName == 'col5'){
     $("#color").attr("href", "https://cpcb.nic.in/css/col5.css");
  }else if(colorName == 'col6'){
     $("#color").attr("href", "https://cpcb.nic.in/css/col6.css");
  }
}
function setActiveStyleSheetEnter(title,event) {
  var keycode = (event.keyCode ? event.keyCode : event.which);
  var colorName = title;
  if(colorName == 'light-blue' && keycode==13){
     $("#color").attr("href", "https://cpcb.nic.in/css/light-blue.css");
  }else if(colorName == 'blue' && keycode==13){
     $("#color").attr("href", "https://cpcb.nic.in/css/blue.css");
  }else if(colorName == 'col5' && keycode==13){
     $("#color").attr("href", "https://cpcb.nic.in/css/col5.css");
  }else if(colorName == 'col6' && keycode==13){
     $("#color").attr("href", "https://cpcb.nic.in/css/col6.css");
  }
}
function getActiveStyleSheet() {
  var i, a;
  for(i=0; (a = document.getElementsByTagName("link")[i]); i++) {
    if(a.getAttribute("rel").indexOf("style") != -1 && a.getAttribute("title") && !a.disabled) return a.getAttribute("title");
  }
  return null;
}

function getPreferredStyleSheet() {
  var i, a;
  for(i=0; (a = document.getElementsByTagName("link")[i]); i++) {
    if(a.getAttribute("rel").indexOf("style") != -1
       && a.getAttribute("rel").indexOf("alt") == -1
       && a.getAttribute("title")
       ) return a.getAttribute("title");
  }
  return null;
}

function createCookie(name,value,days) {
  if (days) {
    var date = new Date();
    date.setTime(date.getTime()+(days*24*60*60*1000));
    var expires = "; expires="+date.toGMTString();
  }
  else expires = "";
  document.cookie = name+"="+value+expires+"; path=/";
}

function readCookie(name) {
  var nameEQ = name + "=";
  var ca = document.cookie.split(';');
  for(var i=0;i < ca.length;i++) {
    var c = ca[i];
    while (c.charAt(0)==' ') c = c.substring(1,c.length);
    if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length,c.length);
  }
  return null;
}

window.onload = function(e) {
  var cookie = readCookie("style");
  var title = cookie ? cookie : getPreferredStyleSheet();
  setActiveStyleSheet(title);
}

window.onunload = function(e) {
  var title = getActiveStyleSheet();
  createCookie("style", title, 365);
}

var cookie = readCookie("style");
var title = cookie ? cookie : getPreferredStyleSheet();
setActiveStyleSheet(title);




</script>
 
 
 
 
 
 
 
