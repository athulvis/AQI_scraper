$(document).ready(function() {
 var callback = function(e){
    console.log(e.type, e);
    var text = e.type;
 var proname = document.getElementById("secrhinput").value;
    var code = e.which ? e.which : e.keyCode;
    if(13 === code){
    var rew = (window.location.href);
    if(rew.search("/cpcb")>0) {
      var url1 = "/search.php";
    }
    else {
      var url1 = "/search.php";
    }
    var res12 = rew.replace(window.location.pathname,url1);
    if(res12.indexOf("?")>0) {
      var n = (res12.indexOf("?"));
       res12 = (res12.substr(0,n));
    }
      window.location= res12+"?s="+proname;
    } 
  
};
$('#secrhinput').keyup(callback);
});

    $(function(){ 

      var count = 0;

