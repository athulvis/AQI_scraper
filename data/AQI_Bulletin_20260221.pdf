          <script>
          i = 0;
          $(document).ready(function(){
            $("#gsc-i-id1").keyup(function(){
              var google_lenght = $(this).val().length;
              if(google_lenght>0){
                 $('#gsst_aw').css({"display":"block"});
				 $('#gsc-search-button-data').removeAttr('style');
				 $('#gs_cb50w').empty();//added on 15-07-2019
				 $('#gs_cb50w').append('×');//added on 15-07-2019
				 
               }else{
                   
                   $('#gsst_aw').css({"display":"none"});
				    $('#gsc-search-button-data').removeAttr('style');
               }
             
            });

             $(".gs_cb50w").click(function(){
                $('#g_frm_data')[0].reset();
				$('#gsst_aw').css({"display":"none"});
             
            });

              $("#gsc-search-button-data").click(function(){
                var google_lenght = $("#gsc-i-id1").val().length;
                if(google_lenght>0){
                  return true;
                }else{
                  return false;
                }
            });

          });
		  
		  function clearSearch(event){
              var keycode = (event.keyCode ? event.keyCode : event.which);
                if (event.keyCode==13) 
                {
                  $('#g_frm_data')[0].reset();
                  $('#gsst_aw').css({"display":"none"});
                  $('#gsc-i-id1').focus();
                }
               
             }
