          Inf("dcf");

        }

        if(fdc==2){

          Inf("dcf-1");

        }

        if(fdc==3){

          Inf("dcf-2");

        }

      })

      $('#nrf').click( function(){

        count = 0; 

        fdc = 0; 

        $("body").removeAttr("class");

      })

