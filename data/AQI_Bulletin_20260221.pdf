<script>
function tabkids(event) {
		//alert('demo');
        var keycode = (event.keyCode ? event.keyCode : event.which);
        if (event.keyCode==9) 
        {
          $('.kids_zn').click();
        }
    }

function tabEnter(link) {
        if (event.keyCode==13) 
        {
          var answer = confirm("This link will take you to an seperate web portal. For any query regarding the content of this portal, please contact Portal's Administrator.")
          if (answer) {
            window.open(link, '_blank'); return false;
          }
          else {
            return false;
          }
        }
    }
	
	
	
	
	
